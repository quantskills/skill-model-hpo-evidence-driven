{
  "output_root": "../outputs/lgbm_grid_search",
  "config": {
    "compatibility": {"profile": "legacy_v1"},
    "input": {
      "feature_path": "toy_factors.csv",
      "label_path": "toy_labels.csv"
    },
    "data": {
      "start_date": 20200102,
      "end_date": 20200331,
      "date_col": "date",
      "ticker_col": "symbol",
      "label_col": "y",
      "ticker_dtype": "preserve",
      "all_null_feature_policy": "allow",
      "strict_point_in_time": false,
      "compute_hash": false
    },
    "validation": {
      "method": "fixed_train_valid_test",
      "train_start": 20200102,
      "train_end": 20200214,
      "valid_start": 20200218,
      "valid_end": 20200306,
      "test_start": 20200310,
      "test_end": 20200331,
      "embargo_days": 1,
      "min_assets_per_date": 3
    },
    "training": {
      "label_window": 1
    },
    "time": {
      "trade_lag_days": 0
    },
    "evaluation": {
      "inner_loop": "fast_evaluator",
      "objective": "rankic_ir"
    },
    "fast_evaluator": {
      "top_quantile": 0.25,
      "bottom_quantile": 0.25
    },
    "space_controller": {
      "enabled": false
    },
    "llm": {
      "enabled": false
    },
    "final_selector": {
      "enabled": false
    },
    "task": {
      "name": "skill_lgbm_grid_search",
      "seed": 42
    },
    "search": {
      "model_type": "lgbm",
      "method": "grid",
      "max_trials": 6,
      "max_rounds": 3,
      "trials_per_round": 2,
      "seed": 42,
      "grid": {
        "strategy": "budgeted_cartesian",
        "numeric_levels": 2,
        "log_levels": 2,
        "choice_policy": "first_last",
        "selection": "evenly_spaced",
        "shuffle": false,
        "seed": 42
      },
      "space": {
        "num_leaves": {
          "type": "choice",
          "values": [
            7,
            15
          ]
        },
        "max_depth": {
          "type": "choice",
          "values": [
            3,
            4
          ]
        },
        "learning_rate": {
          "type": "loguniform",
          "low": 0.03,
          "high": 0.12
        },
        "n_estimators": {
          "type": "choice",
          "values": [
            20,
            40
          ]
        },
        "min_child_samples": {
          "type": "choice",
          "values": [
            4,
            8
          ]
        },
        "subsample": {
          "type": "uniform",
          "low": 0.8,
          "high": 1.0
        },
        "colsample_bytree": {
          "type": "uniform",
          "low": 0.8,
          "high": 1.0
        },
        "lambda_l1": {
          "type": "loguniform",
          "low": 1e-06,
          "high": 0.01
        },
        "lambda_l2": {
          "type": "loguniform",
          "low": 1e-06,
          "high": 0.1
        },
        "min_split_gain": {
          "type": "choice",
          "values": [
            0.0,
            0.001
          ]
        }
      }
    },
    "model": {
      "type": "lgbm"
    },
    "preprocess": {
      "winsorize": {
        "enabled": true,
        "lower": 0.01,
        "upper": 0.99,
        "by": "date"
      },
      "normalize": {
        "method": "zscore_by_date"
      },
      "fillna": {
        "method": "none"
      },
      "after_normalize_fillna": "none"
    }
  }
}
