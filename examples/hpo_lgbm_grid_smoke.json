{
  "output_root": "../outputs/lgbm_grid_smoke",
  "config": {
    "compatibility": {"profile": "legacy_v1"},
    "task": {
      "name": "skill_lgbm_grid_smoke",
      "seed": 42
    },
    "input": {
      "feature_path": "toy_factors.csv",
      "label_path": "toy_labels.csv"
    },
    "data": {
      "start_date": 20200102,
      "end_date": 20200331,
      "date_col": "date",
      "ticker_col": "symbol",
      "label_col": "y",
      "ticker_dtype": "preserve",
      "all_null_feature_policy": "allow",
      "strict_point_in_time": false,
      "compute_hash": false
    },
    "search": {
      "model_type": "lgbm",
      "method": "grid",
      "sampler": "grid",
      "max_trials": 4,
      "max_rounds": 2,
      "trials_per_round": 2,
      "seed": 42,
      "grid_trials": [
        {
          "num_leaves": 7,
          "max_depth": 3,
          "learning_rate": 0.03,
          "n_estimators": 20,
          "min_child_samples": 4,
          "subsample": 0.9,
          "colsample_bytree": 0.9,
          "lambda_l1": 0.0001,
          "lambda_l2": 0.001,
          "min_split_gain": 0.0
        },
        {
          "num_leaves": 15,
          "max_depth": 4,
          "learning_rate": 0.06,
          "n_estimators": 40,
          "min_child_samples": 4,
          "subsample": 0.9,
          "colsample_bytree": 0.9,
          "lambda_l1": 0.0001,
          "lambda_l2": 0.001,
          "min_split_gain": 0.0
        },
        {
          "num_leaves": 15,
          "max_depth": 3,
          "learning_rate": 0.10,
          "n_estimators": 20,
          "min_child_samples": 8,
          "subsample": 0.85,
          "colsample_bytree": 0.85,
          "lambda_l1": 0.001,
          "lambda_l2": 0.01,
          "min_split_gain": 0.001
        },
        {
          "num_leaves": 7,
          "max_depth": 4,
          "learning_rate": 0.12,
          "n_estimators": 40,
          "min_child_samples": 8,
          "subsample": 1.0,
          "colsample_bytree": 1.0,
          "lambda_l1": 0.000001,
          "lambda_l2": 0.000001,
          "min_split_gain": 0.0
        }
      ]
    },
    "model": {
      "type": "lgbm"
    },
    "validation": {
      "method": "fixed_train_valid_test",
      "train_start": 20200102,
      "train_end": 20200214,
      "valid_start": 20200218,
      "valid_end": 20200306,
      "test_start": 20200310,
      "test_end": 20200331,
      "embargo_days": 1,
      "min_assets_per_date": 3
    },
    "training": {
      "label_window": 1
    },
    "time": {
      "trade_lag_days": 0
    },
    "evaluation": {
      "inner_loop": "fast_evaluator",
      "objective": "rankic_ir"
    },
    "fast_evaluator": {
      "top_quantile": 0.25,
      "bottom_quantile": 0.25
    },
    "preprocess": {
      "winsorize": {"enabled": true, "lower": 0.01, "upper": 0.99, "by": "date"},
      "normalize": {"method": "zscore_by_date"},
      "fillna": {"method": "none"},
      "after_normalize_fillna": "none"
    },
    "space_controller": {
      "enabled": false
    },
    "llm": {
      "enabled": false
    },
    "final_selector": {
      "enabled": false
    }
  }
